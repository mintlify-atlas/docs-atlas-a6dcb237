  "keyFeatures": [
    "JWT-based authentication with access and refresh tokens",
    "Video upload with background Cloudinary processing and auto-thumbnail generation",
    "Paginated video feed with search, sort, and filter support",
    "Comment system with likes, CRUD operations, and pagination",
    "Channel subscriptions and subscriber management",
    "Playlist creation, management, and video organization",
    "Per-video view tracking",
    "Channel stats dashboard (subscribers, views, likes, video count)",
    "React frontend with Tailwind CSS, Framer Motion, and custom hooks",
    "Dockerized backend for easy deployment"
  ],
